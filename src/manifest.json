{
  "manifest_version": 3,
  "name": "留友封 (Threads Block Tool)",
  "version": "2.2.2",
  "description": "Threads 批次封鎖、只檢舉、來源分析與「可疑帶風向行為」樣本工具",
  "host_permissions": [
    "*://*.threads.net/*",
    "*://threads.net/*",
    "*://*.threads.com/*",
    "*://threads.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.threads.net/*",
        "*://threads.net/*",
        "*://*.threads.com/*",
        "*://threads.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
