{
  "manifest_version": 2,
  "name": "留友封 (Threads Block Tool)",
  "version": "2.2.2",
  "description": "Threads 批量封鎖工具 (Firefox Extension Build)",
  "browser_specific_settings": {
    "gecko": {
      "id": "threads-blocker@hege",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "*://*.threads.net/*",
    "*://threads.net/*",
    "*://*.threads.com/*",
    "*://threads.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.threads.net/*",
        "*://threads.net/*",
        "*://*.threads.com/*",
        "*://threads.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
